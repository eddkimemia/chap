# Database
DATABASE_URL="file:./db/custom.db"

# For production, use PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/chapke?schema=public"

# Authentication
# NEXTAUTH_SECRET="your-secret-key"     # Only if using NextAuth.js
# NEXTAUTH_URL="https://chapke.co.ke"

# Email (Resend / SendGrid / SES)
# RESEND_API_KEY="re_..."
# SMTP_HOST="..."
# SMTP_PORT=587
# SMTP_USER="..."
# SMTP_PASS="..."
# EMAIL_FROM="noreply@chapke.co.ke"

# SMS (Africa's Talking / Twilio)
# AT_API_KEY="..."
# AT_USERNAME="..."
# TWILIO_ACCOUNT_SID="..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_PHONE_NUMBER="+1..."

# OAuth
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."

# Payments (M-Pesa / Flutterwave / Paystack)
# MPESA_CONSUMER_KEY="..."
# MPESA_CONSUMER_SECRET="..."
# MPESA_PASSKEY="..."
# MPESA_SHORTCODE="..."
# FLUTTERWAVE_SECRET_KEY="..."
# PAYSTACK_SECRET_KEY="..."

# Storage (S3 / Cloudflare R2)
# S3_ENDPOINT="..."
# S3_REGION="..."
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
# S3_BUCKET="..."

# Monitoring
# SENTRY_DSN="..."

# App
# NODE_ENV="development"   # development | production | test
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
